{
  "name": "youtube-converter-pro",
  "version": "1.0.12",
  "description": "YouTube Downloader Desktop",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run web:dev\" \"npm run start\"",
    "web:dev": "cd frontend && npm run dev",
    "server:dev": "cd backend && npm run dev",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "cd backend && npm install",
    "dist": "npm run build:frontend && npm run build:backend && electron-builder",
    "release": "npm version patch && npm run build:frontend && npm run build:backend && electron-builder --publish always && git push --follow-tags"
  },
  "build": {
    "appId": "com.daniel.ytconverterpro",
    "productName": "YouTube Converter Pro",
    "publish": [
      {
        "provider": "github",
        "owner": "danielbeling",
        "repo": "ytdownload"
      }
    ],
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "YouTube Converter Pro"
    },
    "files": [
      "main.js",
      "preload.cjs",
      "icon.png",
      "frontend/dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      "backend/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "electron-is-dev": "^3.0.1"
  }
}
